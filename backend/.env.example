# ─── Flask Core ───────────────────────────────────────────────────────────────
# IMPORTANT: generate strong random secrets for production!
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret
JWT_SECRET_KEY=replace-with-a-different-strong-secret
FLASK_ENV=production

# ─── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cloud_load_management?retryWrites=true&w=majority

# ─── Email Notifications (optional) ──────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# ─── Rate Limiting Storage ────────────────────────────────────────────────────
# Use Redis cloud (e.g. Upstash) in production; falls back to in-memory if not set
RATELIMIT_STORAGE_URL=redis://<host>:<port>/0

# ─── AI Scaling Thresholds (optional tuning) ─────────────────────────────────
SCALE_UP_THRESHOLD=75
SCALE_DOWN_THRESHOLD=40
